# Protect config.php from direct browser access
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

# Protect leads.csv from direct access
<Files "leads.csv">
    Order Allow,Deny
    Deny from all
</Files>

# Prevent directory browsing
Options -Indexes

# PHP settings
php_flag display_errors Off
php_value upload_max_filesize 10M
php_value post_max_size 10M
